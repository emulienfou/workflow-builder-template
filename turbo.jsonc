{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["pnpm-lock.yaml", "patches/*"],
  "tasks": {
    "build": {
      "dependsOn": [
        // Run `build` in workspaces I depend on first
        "^build"
      ],
      // Cache all files emitted to the packages's directories
      "outputs": ["dist/**", ".next/**", "public/_pagefind/**"]
    },
    "docs#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"],
      "env": ["GITHUB_TOKEN", "GITHUB_API_REPO_BASE"]
    },
    "test": {
      "outputs": ["dist/**"]
    },
    "types:check": {
      "dependsOn": [
        // Run `build` in workspaces I depend on first
        "^build"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "dependsOn": [
        // Run `build` in workspaces I depend on first
        "^build"
      ],
      "cache": false
    }
  }
}
