{
  "name": "next-workflow-builder",
  "version": "0.1.0",
  "type": "module",
  "description": "Next.js plugin for Workflow Builder",
  "repository": "https://github.com/emulienfou/next-workflow-builder",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./styles.css": "./dist/styles.css",
    ".": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./api": {
      "types": "./dist/server/api/index.d.ts",
      "import": "./dist/server/api/index.js",
      "require": "./dist/server/api/index.js"
    }
  },
  "bin": {
    "nwb": "src/scripts/nwb.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "NODE_ENV=production tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.9.2",
    "better-auth": "^1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "jiti": "^2.0.0",
    "jotai": "^2.15.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.6",
    "next": "^16",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^3.0.6",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "workflow": "4.0.1-beta.17",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.6",
    "next": "^16",
    "prettier": "^3.7.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "4.1.10",
    "tsup": "^8.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "zx": "^8.2.4"
  },
  "sideEffects": false
}
