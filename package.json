{
  "name": "ai-workflow-builder-template",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "A template for building your own AI-driven workflow automation platform",
  "scripts": {
    "dev": "pnpm discover-plugins && next dev",
    "build": "tsx scripts/migrate-prod.ts && pnpm discover-plugins && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "check": "npx ultracite@latest check",
    "fix": "npx ultracite@latest fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "discover-plugins": "tsx scripts/discover-plugins.ts",
    "create-plugin": "tsx scripts/create-plugin.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.6",
    "knip": "^5.70.1",
    "prettier": "^3.7.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "ultracite": "6.3.0"
  }
}
